{
  "title": "Sentinel · Infrastructure",
  "uid": "sentinel-infra",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {"id": 1, "type": "timeseries", "title": "Pub/Sub backlog (oldest unacked)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"datasource": "Cloud Monitoring", "queryType": "metrics",
        "metricQuery": {"metricType": "pubsub.googleapis.com/subscription/oldest_unacked_message_age"}}]},
    {"id": 2, "type": "timeseries", "title": "Cloud Run instance count",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"datasource": "Cloud Monitoring", "queryType": "metrics",
        "metricQuery": {"metricType": "run.googleapis.com/container/instance_count"}}]},
    {"id": 3, "type": "timeseries", "title": "GKE pod restarts",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "targets": [{"datasource": "Cloud Monitoring", "queryType": "metrics",
        "metricQuery": {"metricType": "kubernetes.io/container/restart_count"}}]}
  ]
}
